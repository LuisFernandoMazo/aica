---
<section class="relative max-w-5xl mx-auto px-4 md:px-8 py-12">

  <!-- Línea vertical -->
  <span class="absolute left-6 top-0 bottom-0 w-px bg-white/30"></span>

  <div class="flex flex-col gap-y-12">

    {PROJECTS.map(({ title, description }) => (
      <article class="scroll-reveal relative pl-14">

        <!-- Bola alineada al título -->
        <span
          class="absolute left-2 md:left-[-8px] top-1/2 -translate-x-1/2 -translate-y-1/2
                 size-[10px] rounded-full bg-yellow-400"
        ></span>

        <!-- Card -->
        <div class="card-tilt bg-[#35245A] rounded-xl p-6 shadow-lg">

          <!-- Título -->
          <h3 class="text-xl md:text-2xl font-bold text-white mb-3 leading-tight">
            {title}
          </h3>

          <ul class="list-disc pl-5 space-y-1 text-white/80">
            {description.map((item) => (
              <li>{item}</li>
            ))}
          </ul>

        </div>
      </article>
    ))}

  </div>
</section>

