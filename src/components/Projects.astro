---
const PROJECTS = [
  {
    title: "Capacitaciones pedagógicas",
    description: [
      "Didáctica y metodologías activas",
      "Planeación de clases efectivas",
      "Recursos educativos innovadores",
    ],
    link: "",
    github: "",
    image: "",
    tags: ["Pedagogía", "Innovación"],
  },
  {
    title: "Seminarios y diplomados",
    description: [
      "Formación continua en temas de educación",
      "Charlas magistrales con expertos",
      "Diplomados certificados en línea",
    ],
    link: "",
    github: "",
    image: "",
    tags: ["Certificado", "Expertos"],
  },
  {
    title: "Actualización normativa",
    description: [
      "Resoluciones y leyes del sector educativo",
      "Interpretación de cambios legales",
      "Guías para el cumplimiento institucional",
    ],
    link: "",
    github: "",
    image: "",
    tags: ["Legal", "Normatividad"],
  },
  {
    title: "Encuentros académicos",
    description: [
      "Jornadas de intercambio entre docentes",
      "Foros y mesas de trabajo",
      "Congresos regionales y nacionales",
    ],
    link: "",
    github: "",
    image: "",
    tags: ["Gremial", "Networking"],
  },
];
---

<section class="relative max-w-5xl mx-auto px-4 md:px-8 py-12">

  <span class="absolute left-6 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-[#fff200] via-[#009640] to-[#ed1c24] opacity-30"></span>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

    {PROJECTS.map(({ title, description, tags }) => (
      <article class="scroll-reveal relative group">
        
        <div class="card-tilt bg-white/5 border border-white/10 rounded-2xl p-8 shadow-2xl backdrop-blur-sm 
                    hover:border-[#009640]/50 transition-all duration-300 h-full flex flex-col">
          
          <div class="flex gap-2 mb-4">
            {tags.map(tag => (
              <span class="text-[10px] uppercase tracking-widest font-bold px-2 py-1 rounded bg-[#ed1c24]/10 text-[#ed1c24] border border-[#ed1c24]/20">
                {tag}
              </span>
            ))}
          </div>

          <h3 class="text-2xl font-bold text-[#fff200] mb-4 leading-tight group-hover:text-white transition-colors">
            {title}
          </h3>

          <ul class="space-y-3 text-gray-300 flex-grow">
            {description.map((item) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-[#009640] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <div class="mt-6 pt-6 border-t border-white/5">
             <button class="text-xs font-semibold text-white/60 group-hover:text-[#fff200] flex items-center gap-2 transition-colors">
               Ver detalles 
               <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
             </button>
          </div>

        </div>
      </article>
    ))}

  </div>
</section>