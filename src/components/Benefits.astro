---
// Componente de Beneficios de Afiliación
const BENEFITS = [
  { text: "Respaldo institucional", icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" },
  { text: "Protección laboral", icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" },
  { text: "Acompañamiento permanente", icon: "M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" },
  { text: "Acceso exclusivo a capacitaciones", icon: "M12 14l9-5-9-5-9 5 9 5z" },
  { text: "Participación en decisiones gremiales", icon: "M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" },
  { text: "Red de apoyo profesional", icon: "M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" },
];
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mt-8">
  {BENEFITS.map((benefit) => (
    <div class="flex items-center gap-4 p-4 rounded-xl bg-white/5 border border-white/10 hover:border-[#009640]/40 hover:bg-white/10 transition-all duration-300 group">
      <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-lg bg-[#009640]/10 text-[#fff200] group-hover:scale-110 transition-transform">
        <svg 
          xmlns="http://www.w3.org/2000/svg" 
          width="24" 
          height="24" 
          viewBox="0 0 24 24" 
          fill="none" 
          stroke="currentColor" 
          stroke-width="2" 
          stroke-linecap="round" 
          stroke-linejoin="round"
        >
          <path d={benefit.icon}></path>
        </svg>
      </div>
      
      <span class="text-sm font-medium text-gray-200 group-hover:text-white transition-colors">
        {benefit.text}
      </span>
    </div>
  ))}
</div>