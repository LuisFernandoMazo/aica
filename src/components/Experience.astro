---
import ExperienceItem from "./ExperienceItem.astro";
const EXPERIENCE = [
  {
    title: "1. Defensa y Representación Laboral",
    description2: "Servicio base que protege los derechos del docente ante cualquier situación laboral.",
    description: [
      "Asesoría jurídica laboral",
      "Acompañamiento en procesos disciplinarios",
      "Orientación en escalafón y carrera docente",
      "Representación ante entidades gubernamentales",
      "Defensa de derechos sindicales",
    ],
    subtitulo: "Incluye:",
  },
  {
    title: "2. Bienestar Integral Docente",
    description2: "Programas y espacios para cuidar la salud emocional y física del maestro.",
    description: [
      "Talleres de manejo del estrés",
      "Prevención del síndrome de burnout",
      "Espacios de escucha y acompañamiento",
      "Jornadas de promoción de la salud",
      "Charlas sobre autocuidado y salud mental",
    ],
    subtitulo: "Actividades:",
  },
  {
    title: "3. Formación y Desarrollo Profesional",
    description2: "Capacitaciones y encuentros que potencian competencias pedagógicas.",
    description: [
      "Capacitaciones pedagógicas",
      "Seminarios y diplomados",
      "Actualización normativa",
      "Certificados de participación",
      "Encuentros académicos",
    ],
    subtitulo: "Ofrecemos:",
  },
  {
    title: "4. Integración y Participación Gremial",
    description2: "Espacios que fortalecen la voz colectiva del magisterio.",
    description: [
      "Asambleas informativas",
      "Encuentros docentes",
      "Espacios de diálogo colectivo",
      "Construcción participativa de propuestas",
    ],
    subtitulo: "Incluye:",
  },
  {
    title: "5. Servicios Digitales",
    description2: "Herramientas en línea para facilitar la interacción y acceso a la información.",
    description: [
      "Atención por WhatsApp institucional",
      "Información actualizada en redes sociales",
      "Boletín digital mensual",
      "Inscripción virtual a eventos",
      "Formularios online de afiliación",
    ],
    subtitulo: "Disponibles:",
  },
];
---

<ol class="relative mt-16">
  {
    EXPERIENCE.map((experience) => (
      <li class="">
        <ExperienceItem {...experience} />
      </li>
    ))
  }
</ol>
