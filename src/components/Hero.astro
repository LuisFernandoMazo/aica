---
/* Hero section for AICA organization. */
---

<div class="relative max-w-4xl text-center mx-auto py-16 px-4">
  <div class="relative inline-block mb-8">
    <div class="absolute inset-0 bg-white/10 blur-2xl rounded-full"></div>
    <img 
      src="https://www.aica.org.co/wp-content/uploads/2023/08/Logo-AICA2.png" 
      alt="Logo AICA" 
      class="relative mx-auto h-28 w-auto drop-shadow-lg" 
    />
  </div>

  <h1 class="text-4xl md:text-5xl font-extrabold mb-6 tracking-tight text-white">
    AICA – Sindicato de Educación <span class="text-[#fff200]">Caquetá</span>
  </h1>

  <p class="text-xl text-gray-200 mb-10 max-w-2xl mx-auto leading-relaxed">
    Defendemos los <span class="text-white font-semibold">derechos laborales</span>, 
    impulsamos el fortalecimiento profesional y garantizamos el 
    <span class="text-white font-semibold">bienestar integral</span> del docente caqueteño.
  </p>

  <nav class="flex flex-wrap justify-center gap-4 mt-8">
    <a href="#afiliacion" class="btn-primary">
      Afíliate ahora
    </a>
    <a href="mailto:info@aica-caqueta.org" class="btn-outline">
      Contáctanos
    </a>
    <a href="https://wa.me/" target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 inline mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
      WhatsApp
    </a>
  </nav>
</div>

<style>
  /* Botón Principal: Rojo vibrante con hover sólido */
  .btn-primary {
    @apply px-8 py-3 rounded-full bg-[#ed1c24] text-white font-bold 
    shadow-lg shadow-red-900/20 hover:bg-[#c81016] hover:scale-105 
    transition-all duration-300 ease-in-out;
  }

  /* Botón Outline: Blanco/Transparente con borde */
  .btn-outline {
    @apply px-8 py-3 rounded-full border-2 border-white/30 text-white font-semibold 
    hover:bg-white hover:text-[#004d21] transition-all duration-300;
  }

  /* Botón WhatsApp: Verde específico o sutil */
  .btn-whatsapp {
    @apply px-8 py-3 rounded-full border-2 border-[#fff200]/50 text-[#fff200] font-semibold 
    hover:bg-[#fff200] hover:text-black transition-all duration-300;
  }
</style>
