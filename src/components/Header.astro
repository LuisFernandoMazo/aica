---
import ThemeToggle from "./ThemeToggle.astro";

const navItems = [
  {
    title: "Experiencia",
    label: "experiencia",
    url: "/#experiencia",
  },
  {
    title: "Proyectos",
    label: "proyectos",
    url: "/#proyectos",
  },
  {
    title: "Habilidades",
    label: "habilidades",
    url: "/#habilidades",
  },
  {
    title: "Sobre mí",
    label: "sobre-mi",
    url: "/#sobre-mi",
  },

  {
    title: "Contacto",
    label: "contacto",
    url: "mailto:lfdo.mazoc@gmail.com",
  },
];
---

<header class="fixed top-0 z-50 w-full">
  <nav
    class="relative flex items-center justify-between px-4 py-3 bg-white/50 dark:bg-transparent backdrop-blur-md shadow-sm ring-1 ring-white/10 sm:justify-center"
  >
    <!-- Menú móvil -->
    <div class="md:hidden">
      <button
        id="mobile-menu-button"
        class="p-2 text-gray-600 dark:text-gray-200 hover:text-blue-500"
        aria-label="Abrir menú"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Menú desktop (oculto en móvil) -->
    <div class="hidden md:flex items-center space-x-4 text-sm">
      {
        navItems.map((link) => (
          <a
            class="px-3 py-2 transition-colors hover:text-blue-500 dark:hover:text-blue-500 relative"
            aria-label={link.label}
            href={link.url}
          >
            {link.title}
          </a>
        ))
      }
    </div>

    <!-- Menú móvil (overlay) -->
    <div
      id="mobile-menu"
      class="absolute top-full left-0 right-0 bg-white dark:bg-gradient-to-r from-gray-700 to-blue-900 shadow-lg md:hidden hidden transition-all duration-300 origin-top"
    >
      <div class="flex flex-col items-center py-4 space-y-3">
        {
          navItems.map((link) => (
            <a
              class="w-full text-center py-2 px-4 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
              aria-label={link.label}
              href={link.url}
            >
              {link.title}
            </a>
          ))
        }
      </div>
    </div>
    <ThemeToggle />
  </nav>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");

    // Toggle mobile menu
    mobileMenuButton?.addEventListener("click", () => {
      mobileMenu?.classList.toggle("hidden");
      mobileMenu?.classList.toggle("scale-y-95");
      mobileMenu?.classList.toggle("opacity-0");
    });

    // Cerrar menú al hacer click fuera
    document.addEventListener("click", (e) => {
      const target = e.target as Node;
      if (
        !mobileMenu?.contains(target) &&
        !mobileMenuButton?.contains(target)
      ) {
        mobileMenu?.classList.add("hidden", "scale-y-95", "opacity-0");
      }
    });

    // Cerrar menú al seleccionar item
    mobileMenu?.querySelectorAll("a").forEach((item) => {
      item.addEventListener("click", () => {
        mobileMenu?.classList.add("hidden", "scale-y-95", "opacity-0");
      });
    });

    // Observador de intersección (actualizado para móvil)
    const config = {
      rootMargin:
        window.innerWidth < 768 ? "-50% 0px -50% 0px" : "0px 0px 0px 0px",
      threshold: 0.3,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          document.querySelectorAll("nav a").forEach((link) => {
            link.classList.toggle(
              "text-blue-500",
              link.getAttribute("aria-label") === entry.target.id
            );
          });
        }
      });
    }, config);

    document
      .querySelectorAll("section")
      .forEach((section) => observer.observe(section));
  });
</script>

<style>
  /* Animaciones mejoradas para móvil */
  #mobile-menu {
    transform: scaleY(0.95);
    opacity: 0;
    transition:
      transform 0.3s ease,
      opacity 0.2s ease;
  }

  #mobile-menu:not(.hidden) {
    transform: scaleY(1);
    opacity: 1;
  }

  /* Mejora de legibilidad en móvil */
  @media (max-width: 767px) {
    nav a {
      font-size: 0.9rem;
      padding: 0.75rem 1rem;
    }

    .dark #mobile-menu {
      background-color: rgba(17, 24, 39, 0.2);
    }
  }
</style>
