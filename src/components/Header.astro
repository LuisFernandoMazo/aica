---
import ThemeToggle from "./ThemeToggle.astro";

const navItems = [
  { title: "Quiénes somos", label: "quienes-somos", url: "/#quienes-somos" },
  { title: "Servicios", label: "servicios", url: "/#servicios" },
  { title: "Capacitaciones", label: "capacitaciones", url: "/#capacitaciones" },
  { title: "Beneficios", label: "beneficios", url: "/#beneficios" },
  { title: "Afiliarse", label: "afiliacion", url: "/#afiliacion" },
  { title: "Contacto", label: "contacto", url: "mailto:info@aica-caqueta.org" },
];
---

<header class="fixed top-0 z-50 w-full px-2 py-4">
  <nav
    class="relative flex items-center justify-between max-w-6xl mx-auto px-4 py-2 bg-white/10 dark:bg-black/20 backdrop-blur-xl rounded-full shadow-2xl ring-1 ring-white/20"
  >
    <a href="/" class="flex items-center flex-shrink-0 transition-transform hover:scale-105">
      <img src="https://www.aica.org.co/wp-content/uploads/2023/08/Logo-AICA2.png" alt="Logo AICA" class="h-10 md:h-12 w-auto" />
    </a>

    <div class="hidden md:flex items-center space-x-1 text-sm font-medium">
      {
        navItems.map((link) => (
          <a
            class="px-3 py-2 text-white/80 transition-all hover:text-[#fff200] rounded-full hover:bg-white/5"
            aria-label={link.label}
            href={link.url}
          >
            {link.title}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-2">
      <ThemeToggle />
      
      <button
        id="mobile-menu-button"
        class="md:hidden p-2 text-white hover:bg-white/10 rounded-full transition-colors"
        aria-label="Abrir menú"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <div
      id="mobile-menu"
      class="absolute top-full left-0 right-0 mt-2 bg-black/90 backdrop-blur-2xl shadow-2xl md:hidden hidden rounded-3xl overflow-hidden border border-white/10"
    >
      <div class="flex flex-col py-4">
        {
          navItems.map((link) => (
            <a
              class="w-full py-3 px-6 text-white/80 hover:text-[#fff200] hover:bg-white/5 transition-colors text-lg"
              aria-label={link.label}
              href={link.url}
            >
              {link.title}
            </a>
          ))
        }
      </div>
    </div>
  </nav>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");

    mobileMenuButton?.addEventListener("click", () => {
      mobileMenu?.classList.toggle("hidden");
    });

    // Cerrar menú al hacer click fuera o en un link
    document.addEventListener("click", (e) => {
      if (!mobileMenu?.contains(e.target as Node) && !mobileMenuButton?.contains(e.target as Node)) {
        mobileMenu?.classList.add("hidden");
      }
    });

    // Highlight del menú según sección activa
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          document.querySelectorAll("nav a").forEach((link) => {
            const isActive = link.getAttribute("aria-label") === entry.target.id;
            link.classList.toggle("text-[#fff200]", isActive);
            link.classList.toggle("font-bold", isActive);
          });
        }
      });
    }, { threshold: 0.5 });

    document.querySelectorAll("section").forEach((s) => observer.observe(s));
  });
</script>

<style>
  /* Animación suave para el menú móvil */
  #mobile-menu:not(.hidden) {
    animation: slideIn 0.3s ease forwards;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>