---
// Pasos para la afiliación a AICA
const STEPS = [
  { 
    title: "Formulario", 
    desc: "Diligenciar formulario online", 
    icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" 
  },
  { 
    title: "Documentación", 
    desc: "Adjuntar documentos requeridos", 
    icon: "M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v8" 
  },
  { 
    title: "Confirmación", 
    desc: "Vía correo o WhatsApp", 
    icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" 
  },
  { 
    title: "¡Bienvenido!", 
    desc: "Bienvenida oficial como afiliado", 
    icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" 
  },
];
---

<div class="relative grid grid-cols-1 md:grid-cols-4 gap-8 mt-12">
  <div class="hidden md:block absolute top-12 left-0 w-full h-0.5 bg-gradient-to-r from-[#fff200] via-[#009640] to-[#ed1c24] opacity-20"></div>

  {STEPS.map((step, index) => (
    <div class="relative flex flex-col items-center text-center group">
      <div class="z-10 flex items-center justify-center w-16 h-16 mb-4 rounded-full bg-[#020617] border-2 border-[#009640] text-[#fff200] group-hover:border-[#fff200] group-hover:scale-110 transition-all duration-300 shadow-xl shadow-[#009640]/10">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d={step.icon} />
        </svg>
        
        <span class="absolute -top-1 -right-1 flex items-center justify-center w-6 h-6 text-xs font-bold text-white bg-[#ed1c24] rounded-full">
          {index + 1}
        </span>
      </div>

      <h3 class="text-white font-bold mb-1">{step.title}</h3>
      <p class="text-sm text-gray-400 leading-tight px-2">
        {step.desc}
      </p>
    </div>
  ))}
</div>